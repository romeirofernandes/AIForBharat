// Prisma Schema for AIForBharat Civic Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique @db.VarChar(255)
  passwordHash    String   @map("password_hash") @db.Text
  role            String   @default("user") @db.VarChar(20)
  reputationScore Int      @default(0) @map("reputation_score")
  createdAt       DateTime @default(now()) @map("created_at")
  issues          Issue[]
  profile         CitizenProfile?
  vehicles        UserVehicle[]
  issueVotes      IssueVote[]
  comments        IssueComment[]
  commentVotes    CommentVote[]
  issueHistories  IssueHistory[]

  @@map("users")
}

model Issue {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  description  String   @db.Text
  latitude     Float?
  longitude    Float?
  imageUrl     String?     @map("image_url") @db.Text
  videoUrl     String?     @map("video_url") @db.Text
  status       String      @default("pending") @db.VarChar(50)
  departmentId Int?        @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])
  incidentType String?     @map("incident_type") @db.VarChar(255)
  priorityScore Float      @default(0) @map("priority_score")
  userId       Int         @map("user_id")
  user         User        @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  votes        IssueVote[]
  comments     IssueComment[]
  history      IssueHistory[]
  workflows    IssueWorkflow[]

  @@map("issues")
}

// ─── Forum: Votes & Threaded Comments ───────────────────────────

model IssueVote {
  id       Int    @id @default(autoincrement())
  issueId  Int    @map("issue_id")
  issue    Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId   Int    @map("user_id")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  value    Int    // +1 or -1

  @@unique([issueId, userId])
  @@map("issue_votes")
}

model IssueComment {
  id        Int            @id @default(autoincrement())
  body      String         @db.Text
  issueId   Int            @map("issue_id")
  issue     Issue          @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId    Int            @map("user_id")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId  Int?           @map("parent_id")
  parent    IssueComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   IssueComment[] @relation("CommentThread")
  votes     CommentVote[]
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@map("issue_comments")
}

model CommentVote {
  id        Int          @id @default(autoincrement())
  commentId Int          @map("comment_id")
  comment   IssueComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    Int          @map("user_id")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int          // +1 or -1

  @@unique([commentId, userId])
  @@map("comment_votes")
}

model CitizenProfile {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  name      String   @db.VarChar(255)
  age       Int?
  gender    String?  @db.VarChar(50)
  imageUrl  String?  @map("image_url") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("citizen_profiles")
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  description String?  @db.Text
  issues      Issue[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("departments")
}

// ─── Issue Timeline History ─────────────────────────────────────

model IssueHistory {
  id        Int      @id @default(autoincrement())
  issueId   Int      @map("issue_id")
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  action    String   @db.VarChar(100)
  actorRole String   @map("actor_role") @db.VarChar(20)
  actorId   Int      @map("actor_id")
  actor     User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")

  @@map("issue_history")
}

// ─── Workflow Engine ────────────────────────────────────────────

model IssueWorkflow {
  id        Int      @id @default(autoincrement())
  issueId   Int?     @map("issue_id")
  issue     Issue?   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  clusterKey String? @map("cluster_key") @db.VarChar(500)
  flowJson  Json     @map("flow_json") @db.JsonB
  status    String   @default("active") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")
  steps     WorkflowStep[]

  @@map("issue_workflows")
}

model WorkflowStep {
  id          Int       @id @default(autoincrement())
  workflowId  Int       @map("workflow_id")
  workflow    IssueWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepId      String    @map("step_id") @db.VarChar(50)
  title       String    @db.VarChar(255)
  description String    @db.Text
  type        String    @db.VarChar(30)
  status      String    @default("pending") @db.VarChar(30)
  notes       String?   @db.Text
  evidenceUrl String?   @map("evidence_url") @db.Text
  assignedTo  String?   @map("assigned_to") @db.VarChar(255)
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("workflow_steps")
}

// ─── Traffic & E-Challan Models ─────────────────────────────────

model TrafficFine {
  id              Int      @id @default(autoincrement())
  srNo            String   @map("sr_no") @db.VarChar(10)
  offenseSection  String   @map("offense_section") @db.VarChar(255)
  offenseName     String   @map("offense_name") @db.Text
  fineAmount      Int      @map("fine_amount")
  repetitiveFine  String   @map("repetitive_fine") @db.VarChar(255)
  challans        TrafficChallan[]
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("traffic_fines")
}

model UserVehicle {
  id            Int      @id @default(autoincrement())
  vehicleNumber String   @map("vehicle_number") @db.VarChar(20)
  userId        Int      @map("user_id")
  user          User     @relation(fields: [userId], references: [id])
  challans      TrafficChallan[]
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([vehicleNumber, userId])
  @@map("user_vehicles")
}

model TrafficChallan {
  id              Int         @id @default(autoincrement())
  challanNumber   String      @unique @map("challan_number") @db.VarChar(30)
  vehicleNumber   String      @map("vehicle_number") @db.VarChar(20)
  vehicle         UserVehicle? @relation(fields: [vehicleId], references: [id])
  vehicleId       Int?        @map("vehicle_id")
  fineId          Int         @map("fine_id")
  fine            TrafficFine @relation(fields: [fineId], references: [id])
  amount          Int
  status          String      @default("unpaid") @db.VarChar(20) // unpaid, paid, contested, cancelled
  location        String?     @db.VarChar(255)
  imageUrl        String?     @map("image_url") @db.Text
  issuedAt        DateTime    @map("issued_at")
  paidAt          DateTime?   @map("paid_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("traffic_challans")
}
